// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "./generated/client"
  engineType    = "binary"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = "mysql://u410995534_harishneela71:CodTech%401208@srv1855.hstgr.io:3306/u410995534_vrukshacompos"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
  cart      Cart?
}

model Product {
  id                 String   @id
  name               String
  category           String
  subCategory        String?
  description        String?  @db.Text
  images             Json // Array of image URLs
  price              Float    @default(0)
  originalPrice      Float    @default(0)
  discountPercentage Float    @default(0)
  rating             Float    @default(4.5)
  reviewCount        Int      @default(0)
  inStock            Boolean  @default(true)
  stockQuantity      Int      @default(0)
  variants           Json // JSON array of variants
  specifications     Json // JSON object of specs
  warranty           String?
  seller             String?  @default("Vruksha Composites")
  isSponsored        Boolean  @default(false)
  deliveryTime       String?  @default("4-5 business days")
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Category {
  id    String  @id
  name  String
  icon  String?
  image String?
}

model Order {
  id                  String   @id @default(cuid())
  userId              Int
  user                User     @relation(fields: [userId], references: [id])
  items               Json     // JSON array of ordered items
  totalAmount         Float
  shippingAddress     Json     // JSON object for address (includes email, phone, fullName, etc.)
  paymentMethod       String
  paymentStatus       String   @default("pending")
  orderStatus         String   @default("placed")
  deliveryStages      Json?    // JSON array of delivery stage objects
  trackingNumber      String?
  trackingLink        String?
  trackingPlatform    String?
  expectedDeliveryDate DateTime?
  internalNote        String?  @db.Text
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Cart {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id])
  items     Json     // JSON array of cart items: { productId, quantity, variant }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Json
}
